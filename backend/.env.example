# Server
PORT=3000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://username:password@host:27017/bar-db

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Email
RESEND_API_KEY=re_...

# AI Services
OPENAI_API_KEY=sk-...
CLAUDE_API_KEY=sk-ant-api03-...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=...
S3_REGION=us-east-2

# WhatsApp (Options: waha, cloudapi, none)
WHATSAPP_PROVIDER=none
WAHA_API_URL=
WAHA_API_KEY=
WAHA_SESSION=default
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# CORS — URL del frontend en Netlify
FRONTEND_URL=https://your-frontend.netlify.app
