# Server
PORT=3000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://username:password@host:27017/bar-db

# Authentication (obligatorio — la app no arranca sin JWT_SECRET)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Seed del superadmin inicial (solo se usa si no existe ningún SUPERADMIN en la BD;
# si faltan estas vars el seed se omite y se loguea un warning)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Email
RESEND_API_KEY=re_...

# AI Services
OPENAI_API_KEY=sk-...
CLAUDE_API_KEY=sk-ant-api03-...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=...
S3_REGION=us-east-2

# WhatsApp (Options: waha, cloudapi, none)
WHATSAPP_PROVIDER=none
WAHA_API_URL=
WAHA_API_KEY=
WAHA_SESSION=default
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# CORS — URL del frontend en Netlify
FRONTEND_URL=https://your-frontend.netlify.app
# Lista opcional de orígenes permitidos separados por coma; si se define, reemplaza
# a la lista construida a partir de FRONTEND_URL
CORS_ORIGINS=

# URL pública del backend (para que WAHA/Meta envíen los webhooks entrantes)
PUBLIC_API_URL=https://apimayabar.marcostorresalarcon.com

# Instagram (OAuth self-service — Instagram API with Instagram Login)
# App creada en developers.facebook.com, redirect URI: {PUBLIC_API_URL}/instagram-accounts/oauth/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Webhook único a nivel de app (Meta no admite una URL distinta por cuenta conectada).
# URL: {PUBLIC_API_URL}/ig/webhook — este token debe coincidir con el configurado en Meta.
INSTAGRAM_VERIFY_TOKEN=

# WhatsApp Cloud API (OAuth self-service — Embedded Signup / Facebook Login for Business)
# Puede ser la misma app de Meta que Instagram (agregando el producto "WhatsApp" + "Facebook Login for Business"),
# o una app separada. Se necesita una "Configuration" de Facebook Login for Business (variante Embedded Signup).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_LOGIN_CONFIG_ID=
